# ── Приложение ───────────────────────────────────────────────────────────
APP_ENV=local
APP_DEBUG=true

# ── PostgreSQL (единая транзакционная БД) ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://orakul:orakul@localhost:5432/orakul

# ── Redis (кэш + брокер + state/refresh-store) ────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Криптография ПДн (152-ФЗ) ─────────────────────────────────────────────
# HMAC-ключ для snils_hash (ключ уникальности «1 человек = 1 аккаунт»). >= 32 байт.
SECURITY_SNILS_HMAC_KEY=change-me-snils-hmac-secret-min-32-bytes
# Fernet-ключ для шифрования ФИО (real_name_enc). Сгенерировать:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECURITY_FIELD_ENCRYPTION_KEY=change-me-32-byte-urlsafe-base64-fernet-key=

# ── JWT-сессии ────────────────────────────────────────────────────────────
# JWT-подпись (HS256). >= 32 байт.
SECURITY_JWT_SECRET=change-me-jwt-secret-min-32-bytes-long
SECURITY_JWT_ALGORITHM=HS256
SECURITY_ACCESS_TOKEN_TTL_SECONDS=900
SECURITY_REFRESH_TOKEN_TTL_SECONDS=2592000
SECURITY_COOKIE_SECURE=true
SECURITY_COOKIE_DOMAIN=

# ── ЕСИА (OIDC) — через сертифицированный шлюз/интегратора ─────────────────
# TODO(identity-infra): значения выдаёт интегратор, держащий СКЗИ КС3/ФСБ.
ESIA_CLIENT_ID=orakul-mnemonic
ESIA_REDIRECT_URI=https://orakul.example/auth/esia/callback
ESIA_AUTHORIZATION_ENDPOINT=https://esia-gateway.example/aas/oauth2/ac
ESIA_TOKEN_ENDPOINT=https://esia-gateway.example/aas/oauth2/te
ESIA_USERINFO_ENDPOINT=https://esia-gateway.example/rs/prns
ESIA_SCOPES=openid snils fullname
ESIA_REQUIRE_CONFIRMED=true

# ── Сезоны ────────────────────────────────────────────────────────────────
# Авто-финализация истёкших сезонов в таймерном season_roll. Боевой
# DisputeGuard блокирует закрытие сезона с открытыми спорами, поэтому ВКЛ.
SEASONS_AUTO_FINALIZE=true

# ── Разрешение споров ─────────────────────────────────────────────────────
# Длительность окна оспаривания после фиксации/пересмотра исхода, в часах.
RESOLUTIONS_DISPUTE_WINDOW_HOURS=72

# ── Платежи (операционная касса) ──────────────────────────────────────────
# Цены тарифов подписки в копейках (никогда не float).
BILLING_MONTHLY_PRICE_KOPECKS=49000
BILLING_ANNUAL_PRICE_KOPECKS=490000

# ── Вебхуки провайдеров (TODO(billing-infra): проверка подписи) ───────────
# Секреты для верификации входящих вебхуков ЮKassa (приём оплат / выплаты).
# WEBHOOK_YOOKASSA_PAYMENT_SECRET=change-me-provider-webhook-secret
# WEBHOOK_YOOKASSA_PAYOUT_SECRET=change-me-provider-payout-secret
